# LLM Provider API Keys — set the one(s) you want to use
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# Optional: Notification channels
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
WEBHOOK_URL=https://your-custom-endpoint.example.com/hook
GITHUB_TOKEN=ghp_your_github_token_here

# Optional: Extend the SSRF blocklist for the generic webhook tool.
# Comma-separated hostnames/IPs that should never be called.
# WEBHOOK_BLOCKED_HOSTS=internal.corp.com,10.0.0.1
